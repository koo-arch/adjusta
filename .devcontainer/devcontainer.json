{
	"name": "adjusta-workspace",
	"dockerComposeFile": [
		"../docker-compose.yml",
		"docker-compose.devcontainer.yml"
	],
	"service": "workspace",
	"workspaceFolder": "/workspace",
	"features": {
		"ghcr.io/devcontainers/features/go:1.3.4": {
			"version": "1.26.0",
			"golangciLintVersion": "2.12.1"
		},
		"ghcr.io/devcontainers/features/node:2.0.0": {
			"version": "25.9"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
	},
	"shutdownAction": "stopCompose",
	"mounts": [
		"source=codex_config,target=/root/.codex,type=volume",
		"source=claude-code-config-${devcontainerId},target=/root/.claude,type=volume",
		"source=github-cli-config-${devcontainerId},target=/root/.config/gh,type=volume"
	],
	"customizations": {
		"vscode": {
			"settings": {
				"go.toolsManagement.autoUpdate": true,
				"editor.formatOnSave": true,
				"files.exclude": {
					"**/.turbo": true,
					"**/node_modules": true
				}
			},
			"extensions": [
				"golang.Go",
				"ms-vscode.vscode-typescript-next",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss",
				"ms-azuretools.vscode-docker",
				"openai.chatgpt"
			]
		}
	},
	"remoteUser": "root"
}
